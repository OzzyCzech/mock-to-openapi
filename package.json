{
  "name": "mock-to-openapi",
  "version": "1.3.1",
  "description": "Cli tool (and library) for converting JSON mock objects to Open API schemas",
  "type": "module",
  "exports": "./src/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OzzyCzech/mock-to-openapi.git"
  },
  "author": "Roman Ozana <roman@ozana.cz> (https://ozana.cz)",
  "bin": {
    "mock-to-openapi": "cli.js"
  },
  "keywords": [
    "openapi",
    "converter",
    "swagger",
    "yaml",
    "json",
    "cli"
  ],
  "scripts": {
    "test": "vitest",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint",
    "examples": "./cli.js ./examples",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist"
  },
  "packageManager": "pnpm@10.33.0",
  "private": false,
  "dependencies": {
    "@biomejs/biome": "^2.4.11",
    "chalk": "^5.6.2",
    "globby": "^16.2.0",
    "luxon": "^3.7.2",
    "meow": "^14.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^8.0.8",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "picomatch": ">=4.0.4"
    }
  }
}
